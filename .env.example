# Functional Consultant Resource Matcher — Environment Variables
# Copy this file to .env and fill in your own keys before running.

# ── Environment mode ────────────────────────────────────────────────────────
# "TESTING" → mocks all LLM and Tavily calls (no API keys needed to try the UI)
# Any other value (DEV / LOCAL / PROD) → uses live API calls
env=TESTING

# ── OpenRouter API key (required for live LLM calls) ────────────────────────
# Free tier available. Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=        # INSERT YOUR OPENROUTER API KEY HERE

# ── Default LLM model ────────────────────────────────────────────────────────
# Any OpenRouter model slug. Free options: https://openrouter.ai/collections/free-models
# Recommended: google/gemma-3-27b:free  or  qwen/qwen3-235b-a22b-thinking:free
DEFAULT_LLM=openrouter/free

# ── FastAPI backend URL (do not change for local development) ────────────────
API_BASE_URL=http://localhost:8000

# ── Tavily API key (required for web search enrichment in live mode) ─────────
# Free dev tier available. Get yours at: https://tavily.com/dashboard
TAVILY_API_KEY=            # INSERT YOUR TAVILY API KEY HERE

# ── Logging verbosity ────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Excel consultant database path ───────────────────────────────────────────
EXCEL_DB_PATH=data/consultant_database.xlsx
